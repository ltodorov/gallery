{
  "name": "gallery",
  "private": "true",
  "version": "1.0.0",
  "description": "A script for generating static HTML photo and video galleries",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "clean": "rimraf dist public/index.html",
    "compile": "tsc",
    "build": "node dist/index.js",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "all": "pnpm compile && pnpm build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "update:biome": "biome migrate --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ltodorov/gallery.git"
  },
  "author": "Lyubomir Todorov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ltodorov/gallery/issues"
  },
  "homepage": "https://github.com/ltodorov/gallery#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.8",
    "html-minifier-terser": "^7.2.0",
    "lefthook": "^2.1.9",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
