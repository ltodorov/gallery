{
  "name": "gallery",
  "private": "true",
  "version": "1.0.0",
  "description": "A script for generating static HTML photo and video galleries",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "clean": "rimraf dist public/index.html",
    "compile": "tsc",
    "build": "node dist/index.js",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "all": "pnpm compile && pnpm build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "update:biome": "biome migrate --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ltodorov/gallery.git"
  },
  "author": "Lyubomir Todorov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ltodorov/gallery/issues"
  },
  "homepage": "https://github.com/ltodorov/gallery#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.2",
    "html-minifier-terser": "^7.2.0",
    "lefthook": "^2.1.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}
